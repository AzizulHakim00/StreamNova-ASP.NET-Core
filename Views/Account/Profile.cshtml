@model ProfileViewModel
@{
    ViewData["Title"] = "Account profile";
}
<section class="page-shell page-top profile-page">
    <div class="admin-heading">
        <div>
            <span class="eyebrow">Account center</span>
            <h1>@Model.Name</h1>
            <p>@Model.Email · @Model.Role · Member since @Model.MemberSinceUtc.ToLocalTime().ToString("MMMM yyyy")</p>
        </div>
        <a class="button button-glass" asp-controller="Watchlist" asp-action="Index">Open My List</a>
    </div>

    @if (TempData["ProfileSuccess"] is string success)
    {
        <div class="alert-success">@success</div>
    }
    @if (TempData["ProfileError"] is string profileError)
    {
        <div class="alert-error">@profileError</div>
    }
    @if (TempData["PasswordError"] is string passwordError)
    {
        <div class="alert-error">@passwordError</div>
    }

    <div class="stat-grid profile-stats">
        <article class="stat-card"><span>My List</span><strong>@Model.WatchlistCount</strong><small>Saved titles</small></article>
        <article class="stat-card"><span>Continue watching</span><strong>@Model.ContinueWatchingCount</strong><small>Active titles</small></article>
        <article class="stat-card"><span>Reviews</span><strong>@Model.ReviewCount</strong><small>Community posts</small></article>
        <article class="stat-card"><span>Role</span><strong class="role-value">@Model.Role</strong><small>Account access</small></article>
    </div>

    <div class="profile-grid">
        <form class="movie-form profile-form" asp-action="UpdateProfile" method="post">
            @Html.AntiForgeryToken()
            <div class="section-heading"><h2>Profile information</h2></div>
            <div class="form-field">
                <label asp-for="Name"></label>
                <input asp-for="Name" />
                <span asp-validation-for="Name" class="field-error"></span>
            </div>
            <div class="form-field">
                <label>Email</label>
                <input value="@Model.Email" disabled />
            </div>
            <button class="button button-primary" type="submit">Save profile</button>
        </form>

        <form class="movie-form profile-form" asp-action="ChangePassword" method="post">
            @Html.AntiForgeryToken()
            <div class="section-heading"><h2>Change password</h2></div>
            <div class="form-field">
                <label for="CurrentPassword">Current password</label>
                <input id="CurrentPassword" name="CurrentPassword" type="password" autocomplete="current-password" required />
            </div>
            <div class="form-field">
                <label for="NewPassword">New password</label>
                <input id="NewPassword" name="NewPassword" type="password" minlength="8" autocomplete="new-password" required />
            </div>
            <div class="form-field">
                <label for="ConfirmPassword">Confirm password</label>
                <input id="ConfirmPassword" name="ConfirmPassword" type="password" minlength="8" autocomplete="new-password" required />
            </div>
            <button class="button button-primary" type="submit">Change password</button>
        </form>
    </div>
</section>
