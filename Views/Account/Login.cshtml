@model LoginViewModel
@{
    ViewData["Title"] = "Sign in";
}

<section class="auth-page" style="--auth-image: url('/images/hero.svg')">
    <div class="auth-shade"></div>
    <div class="auth-card">
        <a class="brand auth-brand" asp-controller="Home" asp-action="Index"><span class="brand-mark">S</span><span>StreamNova</span></a>
        <h1>Welcome back</h1>
        <p>Sign in to continue watching and manage your list.</p>
        <form asp-action="Login" asp-route-returnUrl="@ViewBag.ReturnUrl" method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
            <label asp-for="Email"></label>
            <input asp-for="Email" autocomplete="email" placeholder="you@example.com" />
            <span asp-validation-for="Email" class="field-error"></span>

            <label asp-for="Password"></label>
            <input asp-for="Password" autocomplete="current-password" placeholder="Your password" />
            <span asp-validation-for="Password" class="field-error"></span>

            <label class="checkbox-row">
                <input asp-for="RememberMe" />
                <span>Remember me</span>
            </label>
            <button class="button button-primary button-block" type="submit">Sign in</button>
        </form>
        <p class="auth-switch">New to StreamNova? <a asp-action="Register">Create an account</a></p>
        <div class="demo-credentials">
            <strong>Demo accounts</strong>
            <span>Admin: admin@streamnova.local / Admin@123</span>
            <span>Viewer: user@streamnova.local / User@123</span>
        </div>
    </div>
</section>
