@model RegisterViewModel
@{
    ViewData["Title"] = "Create account";
}

<section class="auth-page" style="--auth-image: url('/images/hero.svg')">
    <div class="auth-shade"></div>
    <div class="auth-card">
        <a class="brand auth-brand" asp-controller="Home" asp-action="Index"><span class="brand-mark">S</span><span>StreamNova</span></a>
        <h1>Create your profile</h1>
        <p>Build a watchlist and keep your viewing progress.</p>
        <form asp-action="Register" method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
            <label asp-for="Name"></label>
            <input asp-for="Name" autocomplete="name" />
            <span asp-validation-for="Name" class="field-error"></span>

            <label asp-for="Email"></label>
            <input asp-for="Email" autocomplete="email" />
            <span asp-validation-for="Email" class="field-error"></span>

            <label asp-for="Password"></label>
            <input asp-for="Password" autocomplete="new-password" />
            <span asp-validation-for="Password" class="field-error"></span>

            <label asp-for="ConfirmPassword"></label>
            <input asp-for="ConfirmPassword" autocomplete="new-password" />
            <span asp-validation-for="ConfirmPassword" class="field-error"></span>

            <button class="button button-primary button-block" type="submit">Create account</button>
        </form>
        <p class="auth-switch">Already registered? <a asp-action="Login">Sign in</a></p>
    </div>
</section>
