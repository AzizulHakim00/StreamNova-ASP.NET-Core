@model Movie
@{
    var hasPlayback = !string.IsNullOrWhiteSpace(Model.VideoUrl);
    var playbackBadge = Model.PlaybackLabel?.Contains("Full", StringComparison.OrdinalIgnoreCase) == true
        ? "Full movie"
        : "Trailer";
}
<article class="movie-card" data-catalog-movie data-playable="@(hasPlayback ? "true" : "false")">
    @if (hasPlayback)
    {
        <a class="movie-card-image" asp-controller="Browse" asp-action="Watch" asp-route-id="@Model.Id" aria-label="Play @Model.Title">
            <img src="@Model.PosterPath" alt="@Model.Title poster" loading="lazy" />
            <span class="movie-card-play">▶</span>
            <span class="playable-badge">@playbackBadge</span>
        </a>
    }
    else
    {
        <a class="movie-card-image" asp-controller="Browse" asp-action="Details" asp-route-id="@Model.Id" aria-label="View @Model.Title details">
            <img src="@Model.PosterPath" alt="@Model.Title poster" loading="lazy" />
            <span class="movie-card-play">ⓘ</span>
        </a>
    }
    <div class="movie-card-body">
        <div class="movie-card-title-row">
            <h3>@Model.Title</h3>
            <span class="score">@Model.Score.ToString("0.0")</span>
        </div>
        <p>@Model.Year · @Model.MaturityRating · @Model.DurationMinutes min</p>
        <div class="movie-card-footer">
            <span class="genre-pill">@Model.Genre</span>
            <div class="movie-card-actions">
                @if (hasPlayback)
                {
                    <a asp-controller="Browse" asp-action="Watch" asp-route-id="@Model.Id">Play</a>
                }
                <a asp-controller="Browse" asp-action="Details" asp-route-id="@Model.Id">Info</a>
            </div>
        </div>
    </div>
</article>
