<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - StreamNova</title>
    <meta name="description" content="StreamNova is a legal movie, TV and anime discovery platform with official trailers, open-license playback and authorised provider links." />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/platform.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/playback.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/watch-upgrade.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/discover.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/catalog-upgrade.css" asp-append-version="true" />
</head>
<body>
<header class="site-header" id="siteHeader">
    <a class="brand" asp-controller="Home" asp-action="Index" aria-label="StreamNova home">
        <span class="brand-mark">S</span><span>StreamNova</span>
    </a>
    <nav class="main-nav" aria-label="Main navigation">
        <a asp-controller="Home" asp-action="Index">Home</a>
        <a asp-controller="Discover" asp-action="Index">Movies & TV</a>
        <a asp-controller="Browse" asp-action="Index">Open Movies</a>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-controller="Watchlist" asp-action="Index">My List</a>
            <a asp-controller="Subscription" asp-action="Index">Plans</a>
            <a asp-controller="Support" asp-action="Index">Support</a>
        }
        @if (User.IsInRole(UserRoles.Admin))
        {
            <a asp-controller="Admin" asp-action="Index">Admin</a>
        }
    </nav>
    <div class="header-actions">
        <form class="header-search" asp-controller="Discover" asp-action="Search" method="get">
            <input type="hidden" name="type" value="all" />
            <input type="hidden" name="region" value="BD" />
            <input type="search" name="q" placeholder="Movies, TV, anime...  /" aria-label="Search movies TV and anime" required />
            <button type="submit" aria-label="Search">⌕</button>
        </form>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a class="notification-link" asp-controller="Notifications" asp-action="Index" aria-label="Notifications">◉</a>
            <div class="profile-menu">
                <button class="profile-button" type="button" data-profile-toggle>
                    <span class="avatar">@(User.Identity.Name?[0].ToString().ToUpperInvariant() ?? "U")</span>
                    <span class="profile-name">@User.Identity.Name</span>
                    <span>▾</span>
                </button>
                <div class="profile-dropdown" data-profile-menu>
                    <span class="dropdown-label">Signed in as</span>
                    <strong>@User.Identity.Name</strong>
                    <a asp-controller="Notifications" asp-action="Index">Notifications</a>
                    <a asp-controller="Subscription" asp-action="Index">Membership plan</a>
                    <a asp-controller="Support" asp-action="Index">Help center</a>
                    <a asp-controller="Account" asp-action="Profile">Account profile</a>
                    @if (User.IsInRole(UserRoles.Admin))
                    {
                        <a asp-controller="Support" asp-action="Admin">Support operations</a>
                        <a asp-controller="Admin" asp-action="Index">Admin dashboard</a>
                    }
                    <form asp-controller="Account" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit">Sign out</button>
                    </form>
                </div>
            </div>
        }
        else
        {
            <a class="button button-small button-primary" asp-controller="Account" asp-action="Login">Sign in</a>
        }
    </div>
</header>

<main>
    @RenderBody()
</main>

<footer class="site-footer">
    <div>
        <a class="brand brand-footer" asp-controller="Home" asp-action="Index"><span class="brand-mark">S</span><span>StreamNova</span></a>
        <p>Legal discovery, official trailers, open-license playback and authorised streaming-provider links.</p>
        <small>This product uses the TMDB API but is not endorsed or certified by TMDB. Availability data supplied by JustWatch.</small>
    </div>
    <div class="footer-links">
        <a asp-controller="Discover" asp-action="Index">Movies & TV</a>
        <a asp-controller="Browse" asp-action="Index">Open Movies</a>
        <a asp-controller="Subscription" asp-action="Index">Plans</a>
        <a asp-controller="Support" asp-action="Index">Support</a>
        <a href="https://www.themoviedb.org" target="_blank" rel="noopener noreferrer">TMDB ↗</a>
        <a asp-controller="Home" asp-action="Privacy">Privacy</a>
    </div>
</footer>

<script src="~/js/site.js" asp-append-version="true"></script>
<script src="~/js/catalog-upgrade.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
