@model SupportCenterViewModel
@{
    ViewData["Title"] = "Support";
}
<section class="page-shell page-top platform-page">
    <div class="platform-hero-copy">
        <span class="eyebrow">Help center</span>
        <h1>How can we help?</h1>
        <p>Create a tracked request for account, playback, billing, or content issues. Replies appear here and in your notifications.</p>
    </div>

    @if (TempData["Success"] is string success)
    {
        <div class="alert-success">@success</div>
    }

    <div class="support-layout">
        <form class="support-form" asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <h2>Open a ticket</h2>
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
            <label asp-for="Input.Subject"></label>
            <input asp-for="Input.Subject" placeholder="Briefly describe the problem" />
            <span asp-validation-for="Input.Subject" class="field-error"></span>

            <div class="support-form-grid">
                <div>
                    <label asp-for="Input.Category"></label>
                    <select asp-for="Input.Category">
                        <option>General</option>
                        <option>Account</option>
                        <option>Playback</option>
                        <option>Billing</option>
                        <option>Content request</option>
                    </select>
                </div>
                <div>
                    <label asp-for="Input.Priority"></label>
                    <select asp-for="Input.Priority">
                        <option value="Low">Low</option>
                        <option value="Normal">Normal</option>
                        <option value="High">High</option>
                    </select>
                </div>
            </div>

            <label asp-for="Input.Description"></label>
            <textarea asp-for="Input.Description" rows="7" placeholder="Include the steps you tried and any error message."></textarea>
            <span asp-validation-for="Input.Description" class="field-error"></span>
            <button class="button button-primary" type="submit">Submit ticket</button>
        </form>

        <div class="ticket-history">
            <div class="section-heading"><h2>Your tickets</h2><span>@Model.Tickets.Count total</span></div>
            @if (Model.Tickets.Count == 0)
            {
                <div class="ticket-empty"><p>No requests yet. New tickets will appear here.</p></div>
            }
            @foreach (var ticket in Model.Tickets)
            {
                <article class="ticket-card">
                    <div class="ticket-card-head">
                        <div>
                            <span class="ticket-id">#@ticket.Id.ToString()[..8].ToUpperInvariant()</span>
                            <h3>@ticket.Subject</h3>
                        </div>
                        <span class="ticket-status status-@ticket.Status.Replace(" ", "-").ToLowerInvariant()">@ticket.Status</span>
                    </div>
                    <p>@ticket.Description</p>
                    <div class="ticket-meta"><span>@ticket.Category</span><span>@ticket.Priority priority</span><span>@ticket.UpdatedAtUtc.ToString("dd MMM yyyy")</span></div>
                    @if (!string.IsNullOrWhiteSpace(ticket.AdminResponse))
                    {
                        <div class="ticket-response"><strong>StreamNova support</strong><p>@ticket.AdminResponse</p></div>
                    }
                </article>
            }
        </div>
    </div>
</section>
