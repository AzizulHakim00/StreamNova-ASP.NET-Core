@model DiscoveryHomeViewModel
@{
    ViewData["Title"] = "Movies, TV & Anime";
    var shelves = new (string Id, string Eyebrow, string Title, List<DiscoveryTitleViewModel> Items)[]
    {
        ("trending", "This week", "Trending now", Model.Trending),
        ("now-playing", "In cinemas", "Now playing", Model.NowPlaying),
        ("top-rated", "All-time favorites", "Top rated movies", Model.TopRated),
        ("movies", "Popular", "Movies", Model.Movies),
        ("tv", "Binge-worthy", "TV shows", Model.TvShows),
        ("airing", "Fresh episodes", "Airing today", Model.AiringToday),
        ("anime", "From Japan", "Popular anime", Model.Anime),
        ("k-drama", "From Korea", "K-drama spotlight", Model.KoreanDrama),
        ("upcoming", "Coming soon", "Upcoming movies", Model.Upcoming),
        ("documentaries", "Real stories", "Documentaries", Model.Documentaries)
    };
}

<section class="discover-hero">
    <div class="discover-hero-shade"></div>
    <div class="page-shell discover-hero-content">
        <span class="eyebrow">Legal global discovery</span>
        <h1>Every story.<br />One place.</h1>
        <p>Explore live movies, TV, anime, K-drama and documentaries. Play official trailers, inspect cast and seasons, and find authorised streaming, rental and purchase providers in your region.</p>
        <form class="discover-search" asp-controller="Discover" asp-action="Search" method="get">
            <input type="search" name="q" placeholder="Search movies, series, actors or anime..." aria-label="Search the legal catalog" required />
            <select name="type" aria-label="Content type">
                <option value="all">Everything</option>
                <option value="movie">Movies</option>
                <option value="tv">TV shows</option>
                <option value="anime">Anime</option>
            </select>
            <select name="region" aria-label="Provider region">
                <option value="BD" selected="@(Model.Region == "BD" ? "selected" : null)">Bangladesh</option>
                <option value="US" selected="@(Model.Region == "US" ? "selected" : null)">United States</option>
                <option value="GB" selected="@(Model.Region == "GB" ? "selected" : null)">United Kingdom</option>
                <option value="IN" selected="@(Model.Region == "IN" ? "selected" : null)">India</option>
                <option value="JP" selected="@(Model.Region == "JP" ? "selected" : null)">Japan</option>
                <option value="KR" selected="@(Model.Region == "KR" ? "selected" : null)">South Korea</option>
                <option value="CA" selected="@(Model.Region == "CA" ? "selected" : null)">Canada</option>
                <option value="AU" selected="@(Model.Region == "AU" ? "selected" : null)">Australia</option>
            </select>
            <button class="button button-primary" type="submit">Search</button>
        </form>
        <div class="discover-hero-actions">
            <a class="button button-light" asp-controller="Browse" asp-action="Index">▶ Full open movies</a>
            <a class="button button-glass" href="#trending">Browse live catalog</a>
        </div>
        <nav class="discover-shortcuts" aria-label="Catalog collections">
            <a href="#now-playing">Now playing</a>
            <a href="#top-rated">Top rated</a>
            <a href="#airing">Airing today</a>
            <a href="#anime">Anime</a>
            <a href="#k-drama">K-drama</a>
            <a href="#upcoming">Coming soon</a>
        </nav>
    </div>
</section>

<section class="page-shell discover-catalog" id="trending">
    @if (!Model.IsConfigured)
    {
        <div class="catalog-setup-panel">
            <div>
                <span class="eyebrow">One-time setup required</span>
                <h2>Connect your free TMDB token</h2>
                <p>The complete legal catalog is already built. Add the server environment variable <code>TMDB_READ_ACCESS_TOKEN</code> to activate live movies, TV, anime, trailers and provider data.</p>
            </div>
            <a class="button button-primary" href="https://www.themoviedb.org/settings/api" target="_blank" rel="noopener noreferrer">Get TMDB token ↗</a>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert-error">@Model.ErrorMessage</div>
    }

    @foreach (var shelf in shelves)
    {
        if (shelf.Items.Count == 0)
        {
            continue;
        }

        <section class="discovery-row" id="@shelf.Id">
            <div class="section-heading">
                <div><span class="eyebrow">@shelf.Eyebrow</span><h2>@shelf.Title</h2></div>
                <span class="shelf-count">@shelf.Items.Count picks</span>
            </div>
            <div class="discovery-rail">
                @foreach (var title in shelf.Items)
                {
                    <partial name="_DiscoveryCard" model="title" />
                }
            </div>
        </section>
    }

    <aside class="tmdb-credit-card">
        <img src="https://www.themoviedb.org/assets/2/v4/logos/v2/blue_square_2-d537fb228cf3ded904ef09b136fe3fec72548ebc1fea3fbbd1ad9e36364db38b.svg" alt="TMDB" />
        <div>
            <strong>Catalog metadata powered by TMDB</strong>
            <p>This product uses the TMDB API but is not endorsed or certified by TMDB. Streaming availability data is supplied by JustWatch and links to authorised provider pages.</p>
        </div>
    </aside>
</section>
